# overlaat.env.example — environment for the Overlaat sidecar services.
#
# Copy to `overlaat.env`, fill in real values, and keep it out of version control
# (chmod 600 recommended — it holds your Postgres credentials).
#
# Both services source this file:
#   - queue-proxy  (overlaat.queue_proxy:app) — the FIFO entry in front of LiteLLM.
#   - usage-api    (overlaat.usage_api:app)   — read-only dashboard over the events.
#
# NOTE: the values below are placeholders. Do NOT commit real credentials.

# ---------------------------------------------------------------------------
# DATABASE_URL — Postgres the instrumentation writes to / the usage-API reads.
# ---------------------------------------------------------------------------
# The queue-proxy emits exactly one lifecycle row per request into `request_events`,
# the host sampler writes into `host_samples`, and cold model loads land in
# `model_loads`. The usage-API only ever reads. Point both at the same database.
#
# The DB is expected to be up; there is no on-disk fallback. If Postgres is down,
# the proxy fails the request cleanly rather than dropping the event silently.
DATABASE_URL=postgresql://user:pass@localhost:5432/overlaat
#
# Opt-in single-box alternative: a local SQLite file (WAL mode), no DB service to run.
# Initialize it with `python -m overlaat.db init "$DATABASE_URL"`.
# DATABASE_URL=sqlite:///./overlaat.db

# ---------------------------------------------------------------------------
# QUEUE_PROXY_UPSTREAM — the LiteLLM gateway the proxy forwards to.
# ---------------------------------------------------------------------------
# Overlaat is a sidecar: it owns the tailnet/LAN-facing port and forwards every
# request to LiteLLM on loopback after it has been admitted by the per-model
# FIFO semaphore. Keep the gateway bound to loopback so the proxy is the only
# entry point (and therefore the single, complete instrumentation site).
QUEUE_PROXY_UPSTREAM=http://127.0.0.1:4002

# ---------------------------------------------------------------------------
# QUEUE_PROXY_LITELLM_CONFIG — path to the LiteLLM config the proxy reads.
# ---------------------------------------------------------------------------
# The proxy parses the gateway's model list from this YAML so it can size one
# semaphore per model. Each model's concurrency cap is *derived* from the
# backend config (e.g. the per-model parallelism a backend advertises), not
# tuned independently here — so this file is the single source of truth.
QUEUE_PROXY_LITELLM_CONFIG=./litellm-config.yaml

# ---------------------------------------------------------------------------
# Cost-weighted scheduler (see docs/COST-SCHEDULER.md).
# ---------------------------------------------------------------------------
# The scheduler replaces the N independent per-model semaphores with named
# RESOURCE POOLS: each model is assigned to exactly one pool (default `default`),
# and admission is cost-weighted against THAT pool's own budget. Admission
# requires BOTH the per-model cap (in_flight < cap) AND pool budget room
# (used[pool] + cost <= B_pool). cost(model) = 1/cap by default. A pool blocked on
# budget never idles a DIFFERENT pool (cross-backend isolation). With every model
# in one pool this reduces to the previous single-shared-budget behavior exactly.
# It is ON BY DEFAULT. Per-pool budgets + an `exclusive` mutex flag are declared
# in the `overlaat.pools` section of the LiteLLM config (see the example config
# and docs/COST-SCHEDULER.md), NOT here — there is no new env knob.
#
# OVERLAAT_SCHEDULER — "on" (default) | "off". "off" is a kill-switch that
# restores the exact per-model asyncio.Semaphore FIFO path (no global budget,
# no priority, no aging). Flip to off if you want today's independent caps.
OVERLAAT_SCHEDULER=on
#
# OVERLAAT_BUDGET — the DEFAULT pool budget: it is the budget of the `default`
# pool AND of any pool a model references but does not declare a budget for in
# `overlaat.pools` (an auto-created pool). 1.0 means "cost = 1/cap fractions sum
# to one GPU" within a pool. Per-pool budgets in `overlaat.pools` override it.
OVERLAAT_BUDGET=1.0
#
# OVERLAAT_DEFAULT_COST — cost charged for a model with NO declared cap (and no
# overlaat_cost override). 1.0 = a no-cap model conservatively takes the whole
# GPU. With the scheduler ON, no-cap models are NOT a silent uncounted
# pass-through — they consume budget too.
OVERLAAT_DEFAULT_COST=1.0
#
# OVERLAAT_DEFAULT_PRIORITY — base priority when neither the request body
# ("priority": <int>) nor the key's metadata supplies one. Higher = more urgent.
OVERLAAT_DEFAULT_PRIORITY=0
#
# OVERLAAT_AGING_RATE — linear effective-priority gain per second waited
# (anti-starvation). 0.0 (default) = aging off; a long-waiting job never climbs
# above fresher equal-priority peers on age alone (reservation still bounds the
# head's wait). Set a small positive value to let moderately expensive jobs age in.
OVERLAAT_AGING_RATE=0.0
#
# OVERLAAT_RESERVATION_GRACE — seconds the head waits before its budget
# reservation begins. 0.0 (default) = EAGER reservation (reserve the instant an
# expensive job is the head). Reserved for a future refinement; eager today.
OVERLAAT_RESERVATION_GRACE=0.0
#
# PER-KEY PRIORITY CEILING is NOT set here — it is read from the LiteLLM key
# metadata (LiteLLM_VerificationToken.metadata JSON field "overlaat_priority"),
# cached in-process and refreshed ~60s. effective_priority =
# min(requested_or_default, key_ceiling) + aging(wait). The clamp makes priority
# un-gameable: a batch key provisioned with a low ceiling cannot impersonate an
# interactive key no matter what "priority" it sends. On a SQLite single-box
# (no such table) every key falls back to OVERLAAT_DEFAULT_PRIORITY.
